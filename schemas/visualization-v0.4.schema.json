{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://explainer.local/schemas/visualization-v0.4.schema.json",
  "title": "Visualization Language v0.4",
  "type": "object",
  "required": ["schema_version", "id", "title", "entry", "root_board", "boards"],
  "properties": {
    "schema_version": { "const": "visualization-v0.4" },
    "id": { "$ref": "#/$defs/id" },
    "title": { "$ref": "#/$defs/nonEmptyString" },
    "entry": {
      "type": "object",
      "required": ["architecture"],
      "properties": {
        "architecture": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": false
    },
    "root_board": { "$ref": "#/$defs/id" },
    "boards": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/board" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "nodeRef": { "type": "string", "pattern": "^(modules|value_sites)\\.[a-z][a-z0-9_]*$" },
    "moduleRef": { "type": "string", "pattern": "^modules\\.[a-z][a-z0-9_]*$" },
    "relationRef": { "type": "string", "pattern": "^relations\\.[a-z][a-z0-9_]*$" },
    "board": {
      "type": "object",
      "required": ["id", "title", "summary", "subject_ref", "expansion_depth", "grid", "nodes"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "title": { "$ref": "#/$defs/nonEmptyString" },
        "summary": { "$ref": "#/$defs/nonEmptyString" },
        "parent": { "$ref": "#/$defs/id" },
        "subject_ref": {
          "oneOf": [
            { "const": "architecture" },
            { "$ref": "#/$defs/moduleRef" }
          ]
        },
        "expansion_depth": { "type": "integer", "minimum": 0 },
        "grid": { "$ref": "#/$defs/grid" },
        "lanes": { "type": "array", "items": { "$ref": "#/$defs/lane" } },
        "nodes": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/node" } },
        "occurrence_bindings": { "type": "array", "items": { "$ref": "#/$defs/occurrenceBinding" } },
        "elide": { "type": "array", "items": { "$ref": "#/$defs/elide" } },
        "exclude": { "type": "array", "items": { "$ref": "#/$defs/exclude" } },
        "edge_overrides": { "type": "array", "items": { "$ref": "#/$defs/edgeOverride" } },
        "notes": { "type": "array", "items": { "$ref": "#/$defs/nonEmptyString" } }
      },
      "additionalProperties": false
    },
    "grid": {
      "type": "object",
      "required": ["columns", "rows"],
      "properties": {
        "columns": { "type": "integer", "minimum": 1 },
        "rows": { "type": "integer", "minimum": 1 },
        "column_sizing": { "enum": ["uniform", "content"] },
        "min_col": { "type": "number", "exclusiveMinimum": 0 },
        "col_gap": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "lane": {
      "type": "object",
      "required": ["id", "label", "position"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "label": { "$ref": "#/$defs/nonEmptyString" },
        "position": { "type": "number", "minimum": 0, "maximum": 100 }
      },
      "additionalProperties": false
    },
    "node": {
      "type": "object",
      "required": ["id", "ref", "col", "row"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "ref": { "$ref": "#/$defs/nodeRef" },
        "label": { "$ref": "#/$defs/nonEmptyString" },
        "notation": { "$ref": "#/$defs/nonEmptyString" },
        "role": { "$ref": "#/$defs/nonEmptyString" },
        "detail": { "$ref": "#/$defs/nonEmptyString" },
        "scale": { "$ref": "#/$defs/id" },
        "prominence": { "enum": ["primary", "secondary", "context"] },
        "treatment": { "enum": ["block", "compact", "chip"] },
        "density": { "enum": ["normal", "compact", "micro"] },
        "glyph": { "enum": ["scalar", "vector", "matrix", "pair", "volume"] },
        "operator": { "$ref": "#/$defs/nonEmptyString" },
        "col": { "type": "integer", "minimum": 1 },
        "row": { "type": "integer", "minimum": 1 },
        "board_ref": { "$ref": "#/$defs/id" }
      },
      "additionalProperties": false
    },
    "pathMatch": {
      "oneOf": [
        {
          "type": "object",
          "required": ["relation_ref"],
          "properties": { "relation_ref": { "$ref": "#/$defs/relationRef" } },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["relation_path"],
          "properties": {
            "relation_path": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/relationRef" }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "occurrenceBinding": {
      "type": "object",
      "required": ["match", "from_occurrence", "to_occurrence"],
      "properties": {
        "match": { "$ref": "#/$defs/pathMatch" },
        "from_occurrence": { "$ref": "#/$defs/id" },
        "to_occurrence": { "$ref": "#/$defs/id" }
      },
      "additionalProperties": false
    },
    "elide": {
      "type": "object",
      "required": ["ref"],
      "properties": { "ref": { "$ref": "#/$defs/nodeRef" } },
      "additionalProperties": false
    },
    "exclude": {
      "type": "object",
      "required": ["ref", "reason"],
      "properties": {
        "ref": { "$ref": "#/$defs/nodeRef" },
        "reason": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": false
    },
    "connection": {
      "type": "object",
      "required": ["title", "role", "inside"],
      "properties": {
        "title": { "$ref": "#/$defs/nonEmptyString" },
        "role": { "$ref": "#/$defs/nonEmptyString" },
        "inside": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": false
    },
    "edgeOverride": {
      "type": "object",
      "required": ["match"],
      "properties": {
        "match": { "$ref": "#/$defs/pathMatch" },
        "label": { "$ref": "#/$defs/nonEmptyString" },
        "notation": { "$ref": "#/$defs/nonEmptyString" },
        "tone": { "$ref": "#/$defs/id" },
        "connection": { "$ref": "#/$defs/connection" },
        "route_side": { "enum": ["top", "bottom", "left", "right"] },
        "route_clearance": { "type": "number", "exclusiveMinimum": 0 }
      },
      "additionalProperties": false
    }
  }
}

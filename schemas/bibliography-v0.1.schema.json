{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://explainer.local/schemas/bibliography-v0.1.schema.json",
  "title": "Central Bibliography v0.1",
  "type": "object",
  "required": ["schema_version", "sources"],
  "properties": {
    "schema_version": { "const": "bibliography-v0.1" },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/source" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "source": {
      "type": "object",
      "required": ["id", "kind", "title"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "kind": { "enum": ["paper", "code", "docs", "spec", "source", "protocol"] },
        "title": { "$ref": "#/$defs/nonEmptyString" },
        "authors": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "organization": { "$ref": "#/$defs/nonEmptyString" },
        "year": { "type": "integer", "minimum": 1900 },
        "identifiers": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/nonEmptyString" }
        },
        "repository": { "$ref": "#/$defs/nonEmptyString" },
        "revision": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "path": { "$ref": "#/$defs/nonEmptyString" },
        "url": { "type": "string", "pattern": "^https?://" }
      },
      "additionalProperties": false
    }
  }
}

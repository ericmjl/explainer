{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://explainer.local/schemas/architecture-comparison-v0.1.schema.json",
  "title": "Architecture Comparison v0.1",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "title",
    "status",
    "question",
    "summary",
    "subjects",
    "groups",
    "alignments",
    "findings",
    "open_questions"
  ],
  "properties": {
    "schema_version": { "const": "architecture-comparison-v0.1" },
    "id": { "$ref": "#/$defs/id" },
    "title": { "$ref": "#/$defs/nonEmptyString" },
    "status": { "enum": ["draft", "review", "published", "deprecated"] },
    "question": { "$ref": "#/$defs/nonEmptyString" },
    "summary": { "$ref": "#/$defs/nonEmptyString" },
    "subjects": { "$ref": "#/$defs/subjects" },
    "groups": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/group" }
    },
    "alignments": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/alignment" }
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "open_questions": {
      "type": "array",
      "items": { "$ref": "#/$defs/openQuestion" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "factRef": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$"
    },
    "groupRef": {
      "type": "string",
      "pattern": "^groups\\.[a-z][a-z0-9_]*$"
    },
    "alignmentRef": {
      "type": "string",
      "pattern": "^alignments\\.[a-z][a-z0-9_]*$"
    },
    "sourceRef": {
      "type": "object",
      "required": ["source_ref", "role"],
      "properties": {
        "source_ref": { "$ref": "#/$defs/id" },
        "role": { "$ref": "#/$defs/id" },
        "locator": { "$ref": "#/$defs/nonEmptyString" },
        "note": { "$ref": "#/$defs/nonEmptyString" },
        "excerpt_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "object",
      "required": ["status", "refs"],
      "properties": {
        "status": {
          "enum": [
            "confirmed_from_code",
            "confirmed_from_paper",
            "confirmed_from_docs",
            "inferred",
            "open_question"
          ]
        },
        "refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/sourceRef" }
        }
      },
      "additionalProperties": false
    },
    "openQuestionEvidence": {
      "type": "object",
      "required": ["status", "refs"],
      "properties": {
        "status": { "const": "open_question" },
        "refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/sourceRef" }
        }
      },
      "additionalProperties": false
    },
    "subject": {
      "type": "object",
      "required": ["label", "source_set", "subject_ref", "board_ref"],
      "properties": {
        "label": { "$ref": "#/$defs/nonEmptyString" },
        "source_set": { "$ref": "#/$defs/id" },
        "subject_ref": { "$ref": "#/$defs/factRef" },
        "board_ref": { "$ref": "#/$defs/id" }
      },
      "additionalProperties": false
    },
    "subjects": {
      "type": "object",
      "required": ["primary", "counterpart"],
      "properties": {
        "primary": { "$ref": "#/$defs/subject" },
        "counterpart": { "$ref": "#/$defs/subject" }
      },
      "additionalProperties": false
    },
    "group": {
      "type": "object",
      "required": ["id", "label", "description"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "label": { "$ref": "#/$defs/nonEmptyString" },
        "description": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": false
    },
    "alignment": {
      "type": "object",
      "required": [
        "id",
        "group_ref",
        "label",
        "relationship",
        "primary_refs",
        "counterpart_refs",
        "explanation",
        "evidence"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "group_ref": { "$ref": "#/$defs/groupRef" },
        "label": { "$ref": "#/$defs/nonEmptyString" },
        "relationship": {
          "enum": ["equivalent", "analogous", "changed", "primary_only", "counterpart_only"]
        },
        "primary_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/factRef" }
        },
        "counterpart_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/factRef" }
        },
        "explanation": { "$ref": "#/$defs/nonEmptyString" },
        "evidence": { "$ref": "#/$defs/evidence" }
      },
      "additionalProperties": false
    },
    "finding": {
      "type": "object",
      "required": ["id", "statement", "alignment_refs", "evidence"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "statement": { "$ref": "#/$defs/nonEmptyString" },
        "alignment_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/alignmentRef" }
        },
        "evidence": { "$ref": "#/$defs/evidence" }
      },
      "additionalProperties": false
    },
    "openQuestion": {
      "type": "object",
      "required": ["id", "question", "evidence"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "question": { "$ref": "#/$defs/nonEmptyString" },
        "evidence": { "$ref": "#/$defs/openQuestionEvidence" }
      },
      "additionalProperties": false
    }
  }
}
